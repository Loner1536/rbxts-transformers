{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "Node",
        "outDir": "./out/rotor/src",
        "plugins": [
            {
                "transform": "rbxts-transform-boost",
                "optimize": true,
                "hoist": true
            }
        ]
    },
    "include": [
        "./src/server",
        "./src/shared/tests",
        "./src/shared/fns.ts"
    ],
    "rbxts": {
        "includePath": "out/rotor/include"
    }
}
