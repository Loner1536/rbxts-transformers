{
    "name": "perf-benchmark-roblox-ts",
    "emitLegacyScripts": false,
    "tree": {
        "$className": "DataModel",
        "ServerScriptService": {
            "$path": "out/src/server"
        },
        "ReplicatedStorage": {
            "shared": {
                "$path": "out/src/shared"
            },
            "include": {
                "$path": "out/include",
                "node_modules": {
                    "$className": "Folder",
                    "@rbxts": {
                        "$path": "node_modules/@rbxts"
                    }
                }
            }
        }
    }
}
