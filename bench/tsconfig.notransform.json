{
    "compilerOptions": {
        "target": "ESNext",
        "module": "commonjs",
        "moduleDetection": "force",
        "moduleResolution": "Node",
        "strict": true,
        "noLib": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "./src",
        "outDir": "./out/src",
        "typeRoots": [
            "./node_modules/@rbxts"
        ],
    },
    "include": [
        "./src/shared/fns-bare.ts"
    ],
    "rbxts": {
        "includePath": "out/include"
    }
}
