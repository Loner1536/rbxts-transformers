{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node10",
        "ignoreDeprecations": "5.0",
        "strict": true,
        "declaration": true,
        "outDir": "dist",
        "rootDir": "src",
        "esModuleInterop": true,
        "paths": { "typescript": ["./test/node_modules/typescript"] },
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src"]
}
