{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "declaration": true,
        "outDir": "out",
        "rootDir": "src",
        "esModuleInterop": true,
        "paths": {
            "typescript": [
                "./test/node_modules/typescript"
            ]
        },
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src"
    ]
}
